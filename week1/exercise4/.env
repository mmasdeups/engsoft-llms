# Copy to .env. Default below = your local Ollama: no key, no money, no internet.
OPENAI_ENDPOINT=http://localhost:11434/v1
OPENAI_API_KEY=ollama          # Ollama ignores the value — any string works
MODEL=ministral-3:14b

# To call a frontier model instead, swap the three lines above for, e.g.:
# OPENAI_ENDPOINT=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-key
# MODEL=gpt-4.1-mini
#
# Any OpenAI-compatible provider works the same way — only .env changes:
#   OpenRouter:  https://openrouter.ai/api/v1
#   Groq:        https://api.groq.com/openai/v1
